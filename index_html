                <div id="btn1" onclick="alert('Incrível, né?')">CLIQUE AQUI</div>
            </div>

            <div class="texto1">Criado por mim</div>
        </div>

        <script>
            // MANDA UMA MENSAGEM PARA O CONSOLE DO DESENVOLVEDOR
            console.log("O site abriu."); // REGISTRA O LOG DE ABERTURA
        </script>
    </body>
</html>
